# ============================================
# Configuração Docker - Chat Interno
# ============================================

# Ambiente
APP_ENV=production
APP_SECRET=TROQUE_POR_STRING_ALEATORIA_64_CARACTERES_AQUI

# Banco de Dados (DNS interno do Docker)
DB_HOST=mysql
DB_PORT=3306
DB_HOST_PORT=3307
DB_NAME=chat_db
DB_USER=chat_user
DB_PASS=SenhaForte123!@#
DB_ROOT_PASS=RootSenhaForte456!@#

# Uploads
UPLOAD_MAX_SIZE=10485760
UPLOAD_ALLOWED=jpg,jpeg,png,gif,pdf,doc,docx,zip

# Timezone
TZ=America/Sao_Paulo

# Portas expostas no host da VM
WEB_HOST_PORT=8188

# Usuário admin inicial criado automaticamente no primeiro boot
ADMIN_NAME=Admin
ADMIN_EMAIL=admin@empresa.com
ADMIN_PASSWORD=password